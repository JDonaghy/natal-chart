# Geocoding API URL
# Set this to your Cloudflare Worker URL for real city search
# Leave empty to use mock data (development only)
VITE_GEOCODING_API_URL=

# Note: For production deployment on GitHub Pages, set this in your
# GitHub repository Settings > Secrets and Variables > Actions
# as VITE_GEOCODING_API_URL, and it will be injected during build.

# Example (replace with your actual worker URL):
# VITE_GEOCODING_API_URL=https://natal-chart-geocoding.johnfdonaghy.workers.dev/geocode

# Firebase Authentication (optional — app works without login)
# Create a Firebase project at https://console.firebase.google.com
# Enable Authentication > Sign-in method > Google (and/or GitHub)
# Copy config from Project Settings > General > Your apps > Firebase SDK snippet
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=